# Plantilla de variables de entorno. Copia a `.env.local` y rellena los valores
# reales (nunca versiones `.env.local`). El sitio arranca y responde 200 aunque
# falten: cada cliente (Prisma, Resend, Stripe) degrada de forma null-safe.

# --- Base de datos (Prisma / Supabase Postgres) ---
# Necesaria para persistir leads, suscriptores y pedidos. Las migraciones la exigen.
DATABASE_URL=

# --- Email transaccional (Resend + React Email) ---
RESEND_API_KEY=
EMAIL_FROM="Portfolio <onboarding@resend.dev>"
CONTACT_TO_EMAIL=hola@alexendros.dev

# --- Pagos (Stripe Checkout) ---
# Clave secreta del servidor (sk_test_… / sk_live_…). Sin ella, /api/checkout
# responde 503 y la UI ofrece el canal de contacto como fallback.
STRIPE_SECRET_KEY=
# Secreto de firma del webhook (whsec_…), del Dashboard o `stripe listen`.
STRIPE_WEBHOOK_SECRET=

# --- URLs ---
# Origen público absoluto; fallback para las success/cancel URLs de Checkout.
NEXT_PUBLIC_BASE_URL=https://alexendros.dev
